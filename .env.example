# OpenRouter Agent Configuration
# Copy this file to .env and fill in your values

# Required: Your OpenRouter API key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use (see https://openrouter.ai/models)
OPENROUTER_MODEL=inclusionai/ling-2.6-1t:free

# API base URL (default https://openrouter.ai/api/v1).
# A non-openrouter.ai host switches to the OpenAI chat-completions dialect.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Maximum LLM interaction turns (default 25)
OPENROUTER_MAX_TURNS=25

# Provider routing: comma-separated order of providers to try
# OPENROUTER_ORDER=OpenRouter,Google,Anthropic

# Provider routing: restrict to specific providers only
# OPENROUTER_ONLY=Google

# Tavily search API key (optional, for WebSearch tool)
TAVILY_API_KEY=tvly-your-key-here

# Enable debug logging
DEBUG=false

# --- Sampling / generation (all optional) ---
# OPENROUTER_TEMPERATURE=1.0
# OPENROUTER_TOP_P=1.0
# OPENROUTER_MIN_P=0
# OPENROUTER_TOP_K=0
# OPENROUTER_FREQUENCY_PENALTY=0
# OPENROUTER_PRESENCE_PENALTY=0
# OPENROUTER_REPETITION_PENALTY=1.0
# OPENROUTER_SEED=
# OPENROUTER_MAX_COMPLETION_TOKENS=     # output token cap (max_completion_tokens)

# --- Reasoning (optional) ---
# OPENROUTER_REASONING_EFFORT=high      # low | medium | high
# OPENROUTER_REASONING_MAX_TOKENS=
# OPENROUTER_REASONING_EXCLUDE=false
# OPENROUTER_REASONING_ENABLED=true

# --- Provider routing (optional) ---
# OPENROUTER_PROVIDER_AVOID=            # comma-separated providers to avoid
# OPENROUTER_PROVIDER_SORT=price        # price | throughput | latency
# OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true
# OPENROUTER_PROVIDER_REQUIRE_PARAMETERS=false
# OPENROUTER_PROVIDER_DATA_COLLECTION=allow   # allow | deny

# --- Semantic memory recall (optional) ---
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Runtime behavior (optional) ---
# OPENROUTER_AUTO_WAKE=false            # wake the loop when idle background jobs exit
# OPENROUTER_EMPTY_TURN_RECOVERY=true   # retry/nudge on an empty terminal turn
# OPENROUTER_EMPTY_TURN_RETRIES=2       # raw retries before nudging

# --- Storage namespace (optional) ---
# Storage namespace for .<appName>/memory, todos, sessions, and temp logs (default: agent-sdk)
# AGENT_SDK_APP_NAME=agent-sdk
